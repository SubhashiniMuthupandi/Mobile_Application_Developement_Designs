package com.example.exercise2
import android.content.Intent;
import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.EditText;
import android.widget.Spinner;
import androidx.appcompat.app.AppCompatActivity;
public class MainActivity extends AppCompatActivity {
    EditText editTextName;
    Spinner spinnerYear;
    Button buttonNext;
    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main)
        editTextName = findViewById(R.id.editTextText);
        spinnerYear = findViewById(R.id.spinner);
        buttonNext = findViewById(R.id.button);
        buttonNext.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {
                String name = editTextName.getText().toString();
                String department = spinnerYear.getSelectedItem().toString(); // department instead of year
                Intent intent = new Intent(MainActivity.this, MainActivity1.class);
                Bundle b = new Bundle();
                b.putString("uname", name);
                b.putString("department", department);
                intent.putExtras(b);
                startActivity(intent);
            }
        });
    }
}
